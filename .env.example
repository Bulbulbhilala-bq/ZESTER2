# ── ZEST Backend Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Admin API key — change this to a long random string!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=3563f44b2771bc481bd72b12a5add65b0bfdb400cb5a3fc7728d21313bdb92ff

# Set to "true" only during local development
FLASK_DEBUG=false

# Port to run on
PORT=5000

# Comma-separated allowed origins for CORS
# Example for production: https://yourdomain.com
ALLOWED_ORIGINS=https://zester-2.vercel.app
